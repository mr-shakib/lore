# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Lore API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"       # development | staging | production
DEBUG=true
SECRET_KEY="change-me-before-production-use"

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Supabase free tier: Project Settings → Database → Connection string
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/lore"

# ── Neo4j (AuraDB Free) ───────────────────────────────────────────────────────
# AuraDB Free: https://console.neo4j.io → New Instance → Free
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password"
NEO4J_DATABASE="neo4j"

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# https://console.upstash.com → Redis → Create Database
REDIS_URL="redis://localhost:6379"
# For Upstash REST API (optional — used for edge/serverless):
# REDIS_REST_URL="https://xxx.upstash.io"
# REDIS_REST_TOKEN="AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA"

# ── Upstash Kafka ─────────────────────────────────────────────────────────────
# https://console.upstash.com → Kafka → Create Cluster
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_USE_SASL=false
# For Upstash Kafka (SASL/SCRAM):
# KAFKA_BOOTSTRAP_SERVERS="xxx.upstash.io:9092"
# KAFKA_USE_SASL=true
# KAFKA_USERNAME="your-upstash-kafka-username"
# KAFKA_PASSWORD="your-upstash-kafka-password"
KAFKA_TOPIC_EVENTS="lore.events"
KAFKA_TOPIC_CORRECTIONS="lore.corrections"
KAFKA_CONSUMER_GROUP="lore-backend"

# ── LLM Providers ────────────────────────────────────────────────────────────
# Pattern mining uses the cheaper model; context injection uses the better one.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_API_KEY=""
PATTERN_MINING_MODEL="gpt-4o-mini"         # cheap, fast
CONTEXT_INJECTION_MODEL="claude-3-haiku-20240307"   # quality matters here

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""
CLERK_WEBHOOK_SECRET=""          # Svix webhook secret for Clerk user events

# ── Integrations ──────────────────────────────────────────────────────────────
# Slack
SLACK_SIGNING_SECRET=""          # App credentials → Signing Secret
SLACK_BOT_TOKEN=""               # OAuth & Permissions → Bot Token (xoxb-...)

# Linear
LINEAR_WEBHOOK_SECRET=""         # Settings → API → Webhooks → Secret

# GitHub
GITHUB_WEBHOOK_SECRET=""         # Repo → Settings → Webhooks → Secret

# ── Rate Limits ───────────────────────────────────────────────────────────────
EVENT_RATE_LIMIT_PER_WORKSPACE=1000   # events/minute before backpressure
CONTEXT_API_RATE_LIMIT=100            # context requests/minute per workspace
